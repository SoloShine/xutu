            "signature": "python -m src.novel_kg.mcp_cli enforce_style_gate --project <proj> --chapter N  # 内部跑 validators.recompute_grep(), 不读 agent 自报\npython -m src.novel_kg.mcp_cli enforce_suspense_gate --project <proj> --chapter N --vdd-version <hash>  # 复算 threads_consumed 从 thread_updates，对照 VDD 分配\npython -m src.novel_kg.mcp_cli enforce_pronoun_gate --project <proj> --chapter N  # 扫描正文代词 vs pronoun_lock"
