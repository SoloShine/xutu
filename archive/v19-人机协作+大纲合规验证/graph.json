  "style_guides": {
    "sensory_first": {
      "rule": "感官驱动叙事：用声音、温度、触感推进场景，避免抽象心理描写。本章必须出现至少3种不同感官体验",
      "id": "sensory_first"
    },
    "no_inner_monologue": {
      "rule": "禁止内心独白标记：不使用\"他想\"\"她觉得\"\"心中暗想\"等词，用动作和环境细节暗示内心状态",
      "id": "no_inner_monologue"
    },
    "show_dont_tell": {
      "rule": "展示而非宣告：不说\"他做了决定\"，而是描写他站起来走向门口的动作。不说\"气氛紧张\"，而是写\"茶杯里的水停止了震动\"",
      "id": "show_dont_tell"
    },
    "dash_restriction": {
      "rule": "破折号限制：整章使用破折号不超过2次",
      "id": "dash_restriction"
    },
    "anti_pattern": {
      "rule": "禁止\"不是X是Y\"句式（如\"不是恐惧是愤怒\"），每章最多出现0次",
      "id": "anti_pattern"
    },
    "rhythm_variation": {
      "rule": "节奏变化：场景间用短句过渡（3-5字），场景内用中长句推进，结尾段落不超过50字",
      "id": "rhythm_variation"
    }
  },
