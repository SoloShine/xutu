      "name": "身体的完整性"
    }
  },
  "style_guides": {
    "style_01": {
      "rule": "零形容词叙事：用动词和名词推进，禁止「恐怖的」「阴森的」等情绪形容词，让场景本身制造恐惧",
      "id": "style_01"
    },
    "style_02": {
      "rule": "感官驱动：优先写触觉和嗅觉（福尔马林味、皮肤的温度、缝合线的质感），视觉放在最后",
      "id": "style_02"
    },
    "style_03": {
      "rule": "沉默代替宣告：角色不解释自己的动机，用行为和选择呈现，禁止内心独白宣告决定",
      "id": "style_03"
    },
    "style_04": {
      "rule": "日常即恐怖：将异常嵌入最平常的工作场景（穿线、翻面、缝合），反差制造不安",
      "id": "style_04"
    },
    "style_05": {
      "rule": "禁止感叹号和省略号：对话正常说，叙述平铺直叙，情绪通过节奏而非标点传达",
      "id": "style_05"
    },
    "style_06": {
      "rule": "每章至少一个具体的感官锚点：一种气味、一种触感、一种声音，贯穿全章反复出现",
      "id": "style_06"
    },
    "style_07": {
      "rule": "限制视角：只从陆安视角叙述，他不知道的读者也不知道，不切换其他角色内心",
      "id": "style_07"
    }
  },
  "motifs": {
    "缝合线": {
      "meaning": "边界、修复与拼接，人的完整性被质疑",
      "evolution": "缝合线从手术痕迹→仪式标记→身份符号",
      "name": "缝合线"
