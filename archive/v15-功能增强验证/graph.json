  "chapter_arcs": {
    "1": {
      "purpose": "建立悬念：异常缝合痕",
      "scenes": "陆安夜班到达殡仪馆做日常准备 → 为一位心梗去世的老人做清洁时发现腹部缝合痕 → 检查缝合线材质确认非医院用线 → 方蕊到场用手机拍下缝合痕特写",
      "ending": "陆安关掉无影灯，缝合线在暗下来的房间里发出最后的反光，像一条不会愈合的伤口",
      "thread_plan": "{\"to_plant\": [\"死者身上的非正常缝合痕迹是谁做的\", \"为什么缝合线用的是早已停产的型号\"], \"to_advance\": [], \"to_resolve\": []}",
      "reasoning": "首章需建立日常与异常的反差，用入殓工作的细节制造不安",
      "chapter": 1
    },
    "2": {
      "purpose": "推进调查：发现规律",
      "scenes": "陆安查看最近三个月遗体记录发现三具类似痕迹 → 陆安在方蕊帮助下对比三具遗体的缝合位置和线材 → 陆安潜入地下标本室发现封存的旧档案",
      "ending": "陆安合上最后一页档案，扉页的日期是1987年，比他出生还早两年，档案封面上用蓝墨水写着两个字：「缝合计划」",
      "thread_plan": "{\"to_plant\": [\"地下标本室的旧档案中有什么——缝合计划\", \"谁在系统性地处理这些遗体\"], \"to_advance\": [\"ST01_01\", \"ST01_02\"], \"to_resolve\": []}",
      "reasoning": "承接第1章悬念，陆安从个案扩展到模式识别",
      "chapter": 2
    },
    "3": {
      "purpose": "外部压力介入：调查者出现",
      "scenes": "许彤以记者身份来访询问殡仪馆最近死亡异常 → 许彤在报社调查死亡数据统计 → 陆安在柳河堤发现被水冲出的带缝合痕迹的动物骨骼",
      "ending": "陆安从河堤捡起一块骨头，缝合线还连在上面，依然带着那股甜味",
      "structure_type": "intercut",
      "time_jumps": "[{\"position\": \"许彤报社调查场景\", \"target\": \"同一天的白天\", \"type\": \"intercut\"}]",
      "thread_plan": "{\"to_plant\": [\"柳河堤的动物骨骼是否与死者有关\"], \"to_advance\": [\"ST01_01\"], \"to_resolve\": [\"ST01_02\"]}",
      "reasoning": "引入许彤增加外部压力，河堤发现将范围从殡仪馆扩展到自然环境",
      "chapter": 3
    },
    "4": {
      "purpose": "真相逼近：发现图案",
      "scenes": "陆安和许彤深夜回殡仪馆调取完整记录 → 方蕊分析最新遗体的缝合位置与之前的差异 → 三具遗体的缝合位置叠加形成几何图案",
      "ending": "方蕊将三具遗体的缝合位置描在透明纸上叠在一起举起对着灯光，连成的形状陆安在1987年的档案里见过",
      "thread_plan": "{\"to_plant\": [\"缝合图案代表什么\"], \"to_advance\": [\"ST01_01\"], \"to_resolve\": [\"ST02_01\"]}",
      "reasoning": "从个案关联到整体图案，调查进入质变阶段",
